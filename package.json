{
	"name": "obsidian-clarify",
	"version": "0.1.0",
	"description": "GTD clarify flow plugin for Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.19.41",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"happy-dom": "^20.9.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"@xstate/react": "^6.1.0",
		"effect": "^3.21.2",
		"obsidian": "latest",
		"preact": "^10.29.2",
		"xstate": "^5.31.1"
	}
}
